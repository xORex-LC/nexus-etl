@startuml
title Diagnostic Layer - Class Diagram (Simplified)
set namespaceSeparator none
skinparam backgroundColor white
skinparam linetype ortho
skinparam defaultFontName Arial
skinparam classBorderThickness 2
skinparam class {
  BackgroundColor #f7e9dc
  BorderColor #d9c2a8
}

enum DiagnosticStage {
  EXTRACT
  MAP
  NORMALIZE
  ENRICH
  VALIDATE
  MATCH
  RESOLVE
  PLAN
  APPLY
  SINK
  CACHE
}

enum DiagnosticSeverity {
  ERROR
  WARNING
}

enum SystemErrorCode {
  OK
  UNKNOWN_CODE
  INTERNAL_ERROR
  DATA_INVALID
  CONFLICT
  AUTH_UNAUTHORIZED
  AUTH_FORBIDDEN
  INFRA_TIMEOUT
  INFRA_UNAVAILABLE
  IO_ERROR
  CACHE_ERROR
}

class RowRef {
  +line_no: int
  +row_id: String
  +identity_primary: String [0..1]
  +identity_value: String [0..1]
}

class DiagnosticItem {
  +stage: DiagnosticStage
  +code: String
  +message: String
  +field: String [0..1]
  +record_ref: RowRef [0..1]
  +details: Map<String, Any> [0..1]
  +severity: DiagnosticSeverity [0..1]
  +from_catalog(catalog, stage, code, field, message, details, severity, default_severity)
}

class TransformResult<T> {
  +record: T
  +errors: List<DiagnosticItem>
  +warnings: List<DiagnosticItem>
  +add_error(stage, code, field, message, details)
  +add_warning(stage, code, field, message, details)
}

class CatalogEntry {
  +diag_code: String
  +system_code: SystemErrorCode
  +default_message: String [0..1]
  +severity: DiagnosticSeverity [0..1]
}

class ErrorCatalog {
  +entries: Map<String, CatalogEntry>
  +strict: bool
  +register(entry)
  +register_many(entries)
  +merge(other, on_conflict)
  +with_strict(strict)
  +contains(diag_code)
  +classify(diag_code: String): SystemErrorCode
  +get_entry(diag_code: String): CatalogEntry
}

class DiagnosticContext {
  +catalog: ErrorCatalog
  +retry_policy: RetryPolicy
  +stop_policy: StopPolicy
  +exit_policy: ExitCodePolicy
  +from_catalog(catalog)
}

class DiagnosticBoundary {
  +diagnostic_boundary(stage, catalog, sink, record_ref)
}

class OperationError {
  +stage: DiagnosticStage
  +code: String
  +message: String
  +field: String [0..1]
  +details: Map<String, Any> [0..1]
}

class "translator.py" as TranslatorFns <<module>> {
  +translate_http(stage, status, body, record_ref): DiagnosticItem
  +translate_execution_result(stage, result, record_ref): DiagnosticItem
  +translate_exception(stage, exc, record_ref): DiagnosticItem
  +system_code_of(diag: DiagnosticItem): SystemErrorCode
}

class RetryPolicy {
  +should_retry(sys: SystemErrorCode, attempt: int): bool
  +max_attempts: int
}

class StopPolicy {
  +is_fatal(sys: SystemErrorCode): bool
  +should_stop_fast(sys: SystemErrorCode, flags): bool
}

class ExitCodePolicy {
  +exit_code(sys: SystemErrorCode): int
}

class DiagnosticPolicies {
  +map_http_status(status: int): SystemErrorCode
  +map_system_code(system_code): String
  +resolve_primary_code(codes, stop_policy): SystemErrorCode
  +default_retry_policy()
  +default_stop_policy()
  +default_exit_policy()
}

ErrorCatalog "1" o-- "*" CatalogEntry
TranslatorFns --> ErrorCatalog
TranslatorFns --> DiagnosticPolicies
DiagnosticPolicies --> SystemErrorCode
DiagnosticContext --> ErrorCatalog
DiagnosticBoundary --> TranslatorFns
DiagnosticBoundary --> ErrorCatalog
DiagnosticBoundary --> OperationError
TransformResult --> DiagnosticItem
DiagnosticItem --> RowRef
OperationError ..> DiagnosticStage
RetryPolicy ..> SystemErrorCode
StopPolicy ..> SystemErrorCode
ExitCodePolicy ..> SystemErrorCode
@enduml
