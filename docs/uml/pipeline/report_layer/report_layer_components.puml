@startuml
set namespaceSeparator none
skinparam componentStyle rectangle
skinparam backgroundColor white
skinparam linetype ortho
skinparam defaultFontName Arial
skinparam component {
  BackgroundColor #f7e9dc
  BorderColor #d9c2a8
}

component "UseCases\n(transform/plan/apply)" as usecases
component "ReportCollector" as collector
component "Report Models\n(meta/summary/items)" as models
component "ReportWriter\n(artifacts)" as writer
component "Report JSON" as json

usecases --> collector
collector --> models
usecases --> writer
writer --> collector
writer --> json

@enduml
