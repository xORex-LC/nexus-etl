@startuml
title Enrich Stage - Activity Diagram (Current)
skinparam backgroundColor white
skinparam linetype ortho
skinparam defaultFontName Arial
skinparam activity {
  BackgroundColor #f7e9dc
  BorderColor #d9c2a8
}

start
:EnrichUseCase.run() consumes ENRICH checkpoint pipeline\n(via PipelineOrchestrator);
:PipelineOrchestrator invokes EnrichStage.run(stream);

repeat
  :Take next TransformResult;
  :EnrichStage enters diagnostic_boundary(ENRICH);
  :EnricherEngine.enrich(result);

  if (row is None?) then (yes)
    :Return input (passthrough);
  else (no)
    :EnricherCore initializes builder + EnrichContext\n+ _FieldMutationTracker + EnricherReport;
    :Ensure meta arrays: enrich_events / resolve_requests;

    if (builder has errors AND fatal classifier unset\nAND some op uses ONLY_NON_FATAL?) then (yes)
      :Append ENRICH_FATAL_POLICY_UNSET warning;
    endif

    repeat
      :Take next EnrichmentOperation;
      if (_should_run_operation(op, errors)?) then (yes)
        :Resolve required_keys via key_registry;
        if (missing required key?) then (yes)
          :OperationReport by strictness\n(ENRICH_MISSING_KEY);
        else (no)
          :Collect candidates\n(compute / generate / provider.fetch);
          if (provider error / mismatch / no candidates?) then (yes)
            :OperationReport by strictness\n(provider/no-candidates code);
          else (no)
            :ConflictResolver.decide(candidates);
            if (AMBIGUOUS?) then (yes)
              :Append ResolveHint to meta.resolve_requests;
              :OperationReport by strictness\n(ENRICH_AMBIGUOUS / NEEDS_RESOLVE);
            elseif (NONE?) then (yes)
              :OperationReport by strictness\n(ENRICH_NO_CANDIDATES);
            else (SELECTED)
              :MergeEngine.should_apply + conflict writer check;
              if (policy skip?) then (yes)
                :Append EnrichEvent(SKIPPED);
              else (no)
                :Validate sink target type (SinkSpec, optional);
                if (sink validation failed?) then (yes)
                  :OperationReport by strictness\n(sink issue as provider_error policy);
                else (no)
                  :Write target field/match_key/secret candidate;
                  :Tracker.register(field, op.name);
                  :Append EnrichEvent(APPLIED);
                endif
              endif
            endif
          endif
        endif

        :Record OperationReport in EnricherReport;
        :Append diagnostics/events/resolve_hints to builder/meta;
        if (stop_on_failed && op_report.outcome == FAILED?) then (yes)
          break
        endif
      else (skip)
        :Skip operation by run_when_errors policy;
      endif
    repeat while (more operations?) is (yes)

    if (secret_candidates empty?) then (yes)
      :Skip secret store phase;
    else (no)
      if (match_key missing?) then (yes)
        :Add SECRET_MATCH_KEY_MISSING error;
      else (no)
        if (secret_store configured?) then (yes)
          :secret_store.put_many(...);
          if (store error?) then (yes)
            :Add SECRET_STORE_ERROR;
          endif
        endif
      endif
      :Set meta.secret_fields;
      :Mask/clear secret fields in row;
      :Clear builder.secret_candidates;
    endif

    :Set meta.enrich_summary = EnricherReport.as_dict();
    :Return TransformResult[enriched];
  endif
repeat while (more input results?) is (yes)

stop

@enduml
