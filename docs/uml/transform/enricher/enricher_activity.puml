@startuml
title Enrich Stage - Activity Diagram (Current)
skinparam backgroundColor white
skinparam linetype ortho
skinparam defaultFontName Arial
skinparam activity {
  BackgroundColor #f7e9dc
  BorderColor #d9c2a8
}

start
:Input TransformResult[normalized];

if (row is None?) then (yes)
  :Return input (no-op);
  stop
endif

:EnrichStage enters diagnostic_boundary(ENRICH);
:EnricherEngine.enrich(input);
:EnricherCore initializes builder + summary;

repeat
  :Take next EnrichmentOperation;
  if (run_when_errors allows?) then (yes)
    :Resolve required keys;
    if (missing key?) then (yes)
      :Apply strictness.on_missing_key;
    else (no)
      :Fetch candidates (provider/generator/compute);
      if (provider error?) then (yes)
        :Apply strictness.on_provider_error;
      elseif (no candidates?) then (yes)
        :Apply strictness.on_no_candidates;
      else (has candidates)
        :ConflictResolver.decide;
        if (ambiguous?) then (yes)
          :Outcome NEEDS_RESOLVE;
          :Append ResolveHint to meta;
        else (selected)
          :MergeEngine.merge;
          :Emit EnrichEvent;
        endif
      endif
    endif
  else (skip)
    :Skip operation;
  endif

  :Update EnricherReport;
  if (stop_on_failed?) then (yes)
    break
  endif
repeat while (more operations?)

if (secret_store exists AND secrets present?) then (yes)
  if (match_key missing?) then (yes)
    :Emit MATCH_KEY_MISSING;
  else (no)
    :secret_store.put_many(...);
  endif
endif

:Attach summary/events/resolve_requests to meta;
:Append boundary errors;
:Return TransformResult[enriched];
stop

@enduml
