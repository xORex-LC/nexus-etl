@startuml
title Enrich Stage - Class Diagram (Current)
set namespaceSeparator none
skinparam backgroundColor white
skinparam linetype ortho
skinparam defaultFontName Arial
skinparam class {
  BackgroundColor #f7e9dc
  BorderColor #d9c2a8
}

class EnrichStage {
  - enricher: EnricherEngine
  - catalog: ErrorCatalog
  + run(source): Iterable[TransformResult]
}

class EnricherEngine {
  - core: EnricherCore
  + enrich(result): TransformResult
}

class EnricherDsl {
  - registry: OperationRegistry
  - providers: ProviderGateway
  + compile(spec: EnrichSpec): EnricherSpec
}

class EnricherCore {
  - spec: EnricherSpec
  - deps: TransformProviderDeps
  - secret_store: SecretStoreProtocol
  - conflict_resolver: ConflictResolver
  - merge_engine: MergeEngine
  + enrich(input): TransformResult
}

class EnrichSpec {
  + enrich: EnrichRules
}

class EnrichRules {
  + match_key: MatchKeySpec
  + secrets: SecretsSpec
  + generate: EnrichRule[*]
  + lookup: EnrichRule[*]
}

class EnrichmentOperation {
  + name: str
  + op_type: EnrichOperationType
  + targets: tuple[str]
  + run_when_errors: RunWhenErrors
  + strictness: StrictnessPolicy
  + merge_policy: MergePolicy
}

class ProviderGateway {
  + lookup(name, deps, key, args): list[dict]
  + exists(name, deps, value, args): dict|None
  + with_defaults(): ProviderGateway
}

class TransformProviderDeps {
  + cache_repo: CacheRepositoryProtocol
  + dictionaries: DictionaryProviderProtocol
}

class OperationRegistry
class SecretStoreProtocol <<protocol>>
class CandidateValue
class OperationReport
class EnricherReport
class TransformResult<T>

EnrichStage --> EnricherEngine
EnricherEngine --> EnricherCore
EnricherEngine ..> EnricherDsl : compile once
EnricherDsl --> EnrichSpec
EnricherDsl --> OperationRegistry
EnricherDsl --> ProviderGateway
EnricherDsl --> EnrichmentOperation
EnricherCore --> EnricherSpec
EnricherCore --> TransformProviderDeps
EnricherCore --> SecretStoreProtocol
EnricherCore --> ConflictResolver
EnricherCore --> MergeEngine
EnricherCore --> EnricherReport
EnricherCore ..> CandidateValue
EnricherCore ..> OperationReport
EnricherCore ..> TransformResult

note right of EnricherDsl
DSL role:
- compile EnrichSpec to EnricherSpec
- build provider-backed operations
- wire match_key/secrets policies
end note

@enduml
