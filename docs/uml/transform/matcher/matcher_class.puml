@startuml
title Matcher Stage - Class Diagram (Current)
set namespaceSeparator none
skinparam backgroundColor white
skinparam linetype ortho
skinparam defaultFontName Arial
skinparam classBorderThickness 2
skinparam class {
  BackgroundColor #f7e9dc
  BorderColor #d9c2a8
}

class MatchStage {
  - matcher: MatchProcessor
  - catalog: ErrorCatalog
  + run(source): Iterable[TransformResult]
}

interface MatchProcessor <<protocol>> {
  + match(enriched): TransformResult[MatchedRow]
  + match_with_source_dedup(enriched): TransformResult[MatchedRow]
  + reset_source_dedup(): None
  + bind_runtime_scope(scope): None
}

class MatchEngine {
  - dsl: MatchDsl
  - matching_rules: MatchingRules
  - core: MatchCore
  + __init__(spec, dataset, cache_repo, resolve_rules, include_deleted, catalog, identity_repo)
  + match(enriched): TransformResult[MatchedRow]
  + match_with_source_dedup(enriched): TransformResult[MatchedRow]
  + match_stream(enriched_source): Iterable[TransformResult[MatchedRow]]
}

class MatchDsl {
  + compile(spec: MatchSpec): MatchingRules
}

class MatchCore {
  - dataset: str
  - cache_repo: CacheRepositoryProtocol
  - identity_repo: IdentityRepository
  - matching_rules: MatchingRules
  - resolve_rules: ResolveRules
  + match(enriched): TransformResult[MatchedRow]
  + match_with_source_dedup(enriched): TransformResult[MatchedRow]
  + match_stream(enriched_source): Iterable[TransformResult[MatchedRow]]
}

class MatchSpec {
  + dataset: str
  + match: MatchBlock
}

class MatchBlock {
  + identity_rules: MatchRule[*]
  + ignored_fields: str[*]
  + source_dedup: SourceDedupSpec
  + fuzzy: FuzzySpec
}

class MatchRule {
  + name: str
  + fields: str[*]
  + primary: str?
}

class SourceDedupSpec {
  + enabled: bool
  + on_duplicate: warn|error
  + on_conflict: warn|error
}

class FuzzySpec {
  + enabled: bool
  + blocking_keys: str[*]
  + comparators: dict[str, exact|casefold|similarity]
  + weights: dict[str, float]
  + accept_threshold: float
  + review_threshold: float
  + tie_delta: float
  + max_candidates: int
  + top_k: int
  + score_round: int
}

class MatchingRules {
  + identity_rules: IdentityRule[*]
  + source_dedup: SourceDedupRules
  + fuzzy: FuzzyScoringRules
  + ignored_fields: set[str]
}

class IdentityRule {
  + name: str
  + build_identity
}

class SourceDedupRules {
  + enabled: bool
  + on_duplicate: str
  + on_conflict: str
}

class FuzzyScoringRules {
  + enabled: bool
  + blocking_keys: str[*]
  + comparators: dict[str, str]
  + weights: dict[str, float]
  + accept_threshold: float
  + review_threshold: float
  + tie_delta: float
  + max_candidates: int
  + top_k: int
  + score_round: int
}

class ResolveRules {
  + build_desired_state
  + build_source_ref
  + diff_policy
  + secret_fields_for_op
  + merge_policy
}

class MatchDecisionStatus <<enum>> {
  MATCHED
  NOT_FOUND
  AMBIGUOUS
  CONFLICT_SOURCE
}

class MatchDecision {
  + status: MatchDecisionStatus
  + reason_code: str
  + message: str?
  + selected: MatchCandidate?
  + candidates: MatchCandidate[*]
  + score: float?
  + meta: dict[str, Any]
}

class MatchCandidate {
  + target_id: str?
  + identity: str?
  + score: float?
  + match_mode: str
  + evidence: dict[str, Any]?
}

class MatchedRow {
  + row_ref: RowRef
  + identity: Identity
  + desired_state: dict[str, Any]
  + existing: dict[str, Any]?
  + fingerprint: str
  + fingerprint_fields: tuple[str, ...]
  + match_decision: MatchDecision
  + source_links: dict[str, Identity]
  + target_id: str?
}

class CacheRepositoryProtocol <<protocol>> {
  + find(dataset, filters, include_deleted, mode)
}

class IdentityRepository <<protocol>> {
  + get_runtime_state(scope, dataset, key)
  + set_runtime_state(scope, dataset, key, value)
}

class TransformResult<T> {
  + record
  + row
  + row_ref
  + match_key
  + meta
  + errors
  + warnings
}

MatchStage --> MatchProcessor
MatchProcessor <|.. MatchEngine
MatchEngine --> MatchDsl
MatchEngine --> MatchCore
MatchDsl --> MatchSpec
MatchSpec --> MatchBlock
MatchBlock --> MatchRule
MatchBlock --> SourceDedupSpec
MatchBlock --> FuzzySpec
MatchDsl --> MatchingRules
MatchingRules o-- IdentityRule
MatchingRules o-- SourceDedupRules
MatchingRules o-- FuzzyScoringRules
MatchCore --> MatchingRules
MatchCore --> ResolveRules
MatchCore --> CacheRepositoryProtocol
MatchCore --> IdentityRepository
MatchedRow --> MatchDecision
MatchDecision --> MatchDecisionStatus
MatchDecision --> MatchCandidate
MatchCore ..> TransformResult
MatchCore ..> MatchedRow

note right of MatchDsl
Compile path:
datasets/<dataset>.match.yaml
-> MatchSpec
-> MatchDsl.compile()
-> MatchingRules
end note

note right of MatchCore
Single matcher-core runtime:
1) identity exact-first
2) fuzzy fallback + scoring
3) source-dedup inside core
4) typed MatchDecision output
end note

@enduml
