@startuml
title Matcher Stage - Class Diagram (Current)
set namespaceSeparator none
left to right direction
hide empty members
skinparam backgroundColor white
skinparam linetype ortho
skinparam defaultFontName Arial
skinparam class {
  BackgroundColor #f7e9dc
  BorderColor #d9c2a8
}

class PipelineContainer {
  + planning_pipeline(): PlanningPipeline
  + match_stage(): MatchStage
}

class PlanningPipeline {
  - _dedup_store: ISourceDedupStore
  + open(...): Iterator[Iterable[TransformResult]]
}

class MatchUseCase {
  + run(row_source, pipeline, dataset, report, catalog): CommandResult
}

class PlanningPipelineHooks {
  - _match_scope: IMatchScopeService
  + plan_hooks(): PipelineHooks
}

class PipelineOrchestrator {
  + run(source): Iterable[TransformResult]
}

class MatchStage {
  - matcher: MatchProcessor
  - catalog: ErrorCatalog
  - _batch_settings: IMatchBatchSettings
  + run(source): Iterable[TransformResult]
}

class MatchEngine {
  - dsl: MatchDsl
  - matching_rules: MatchingRules
  - core: MatchCore
  + __init__(spec, resolve_rules, include_deleted, ..., dedup_store)
  + match(enriched): TransformResult
  + match_with_source_dedup(enriched): TransformResult
}

class MatchCore {
  - dataset: str
  - cache_gateway: MatchRuntimePort
  - matching_rules: MatchingRules
  - resolve_rules: ResolveRules
  - include_deleted: bool
  - catalog: ErrorCatalog
  - _dedup_store: ISourceDedupStore
  + match(enriched): TransformResult[MatchedRow]
  + match_with_source_dedup(enriched): TransformResult[MatchedRow]
  + match_stream(source): Iterable[TransformResult[MatchedRow]]
  - _match_identity(...)
  - _match_with_fuzzy(...)
}

class MatchDsl {
  + compile(spec: MatchSpec): MatchingRules
}

class MatchScopeService {
  - _match_runtime: MatchRuntimePort
  - _run_id: str
  + clear_scope(): None
}

class MatchBatchSettings {
  + batch_size: int
  + flush_interval_ms: int
}

class LocalSourceDedupStore {
  - _seen: dict[str, str]
  + check_and_register(key, fingerprint): DedupResult
  + reset(): None
}

class ScopedSourceDedupStore {
  - _cache_gateway: MatchRuntimePort
  - _scope: str
  - _dataset: str
  - _seen: dict[str, str]
  + check_and_register(key, fingerprint): DedupResult
  + reset(): None
}

class MatcherScoring {
  + rank_candidates(...): list[CandidateScore]
  + is_tie(ranked, tie_delta): bool
}

class PipelineRunContext {
  + dedup_store: ISourceDedupStore
  + batch_index: IBatchIndexService
}

class ResolveRules {
  + build_desired_state(...)
}

class MatchingRules {
  + identity_rules: tuple[IdentityRule, ...]
  + ignored_fields: set[str]
  + build_links: BuildLinks?
  + source_dedup: SourceDedupRules
  + fuzzy: FuzzyScoringRules
}

class SourceDedupRules {
  + enabled: bool
  + on_duplicate: str
  + on_conflict: str
}

class FuzzyScoringRules {
  + enabled: bool
  + blocking_keys: tuple[str, ...]
  + comparators: dict[str, str]
  + weights: dict[str, float]
  + accept_threshold: float
  + review_threshold: float
  + tie_delta: float
  + max_candidates: int
  + top_k: int
  + score_round: int
}

class MatchDecision {
  + status: MatchDecisionStatus
  + reason_code: str
  + selected: MatchCandidate?
  + candidates: tuple[MatchCandidate, ...]
  + score: float?
}

class MatchDecisionStatus <<enum>> {
  MATCHED
  NOT_FOUND
  AMBIGUOUS
  CONFLICT_SOURCE
}

class MatchedRow {
  + row_ref: RowRef
  + identity: Identity
  + desired_state: dict[str, Any]
  + existing: dict[str, Any]?
  + fingerprint: str
  + fingerprint_fields: tuple[str, ...]
  + match_decision: MatchDecision
  + source_links: dict[str, Identity]
  + target_id: str?
}

class MatchProcessor <<protocol>> {
  + match(enriched): TransformResult[MatchedRow]
  + match_with_source_dedup(enriched): TransformResult[MatchedRow]
}

class ISourceDedupStore <<protocol>> {
  + check_and_register(key, fingerprint): DedupOutcome
  + reset(): None
}

class IMatchBatchSettings <<protocol>> {
  + batch_size: int
  + flush_interval_ms: int
}

class IMatchScopeService <<protocol>> {
  + clear_scope(): None
}

class MatchRuntimePort <<protocol>> {
  + find(dataset, filters, include_deleted, mode): list[dict]
  + set_runtime_state(scope, dataset, state_key, state_value): None
  + get_runtime_state(scope, dataset, state_key): str?
  + clear_runtime_scope(scope): None
}

class StageExecutionContext {
  + metadata: PipelineMetadata
  + require(port_type)
  + get(port_type)
}

class ErrorCatalog
class MatchSpec
class "TransformResult<T>" as TransformResultT
class IBatchIndexService <<protocol>>

' Entry / boundary touchpoints
PipelineContainer --> MatchEngine : Singleton (planning path)
PipelineContainer --> MatchStage : Singleton
PipelineContainer --> LocalSourceDedupStore : per-run singleton
PipelineContainer --> PlanningPipeline : Factory
PipelineContainer --> MatchScopeService : Singleton
PipelineContainer ..> PipelineRunContext : contains dedup_store

PlanningPipeline --> ISourceDedupStore : open() -> reset() before run
PlanningPipeline ..> MatchStage : pre-resolve checkpoint includes match
MatchUseCase --> PipelineOrchestrator : MATCH checkpoint pipeline
PipelineOrchestrator --> MatchStage : run(enriched stream)
PlanningPipelineHooks --> IMatchScopeService : on_stage_complete("match")
MatchScopeService ..|> IMatchScopeService
MatchScopeService --> MatchRuntimePort : clear_runtime_scope("run:<id>")

' Stage / engine / core
MatchStage --> MatchProcessor
MatchStage --> IMatchBatchSettings
MatchStage --> ErrorCatalog : diagnostic_boundary
MatchEngine ..|> MatchProcessor
MatchEngine --> MatchDsl
MatchEngine --> MatchCore : delegates
MatchEngine --> StageExecutionContext : ctx.require(MatchRuntimePort)
MatchEngine --> ResolveRules : injected compiled rules
MatchEngine --> ISourceDedupStore : injected dedup_store
MatchEngine --> MatchSpec
MatchDsl --> MatchSpec
MatchDsl --> MatchingRules : compile()

MatchCore --> MatchRuntimePort : exact + fuzzy cache lookups
MatchCore --> MatchingRules
MatchCore --> ResolveRules : build_desired_state(...)
MatchCore --> ISourceDedupStore : source-dedup check/register
MatchCore --> MatcherScoring : rank_candidates()/is_tie()
MatchCore --> ErrorCatalog
MatchCore ..> MatchedRow
MatchCore ..> MatchDecision
MatchCore ..> MatchDecisionStatus
MatchCore ..> TransformResultT

' Compiled rules and runtime services
MatchingRules o-- SourceDedupRules
MatchingRules o-- FuzzyScoringRules
MatchBatchSettings ..|> IMatchBatchSettings
LocalSourceDedupStore ..|> ISourceDedupStore
ScopedSourceDedupStore ..|> ISourceDedupStore
ScopedSourceDedupStore --> MatchRuntimePort : get/set runtime_state
PipelineRunContext o-- ISourceDedupStore : dedup_store
MatchedRow --> MatchDecision
MatchDecision --> MatchDecisionStatus

' Layout helpers
PipelineContainer -[hidden]-> PlanningPipeline
PlanningPipeline -[hidden]-> MatchUseCase
MatchUseCase -[hidden]-> MatchStage
MatchStage -[hidden]-> MatchEngine
MatchEngine -[hidden]-> MatchCore
MatchCore -[hidden]-> MatchRuntimePort
PlanningPipelineHooks -[hidden]-> MatchScopeService
LocalSourceDedupStore -[hidden]-> ScopedSourceDedupStore

note right of MatchCore
Core matcher mechanics:
- identity exact lookup (cache)
- fuzzy fallback + scoring + thresholds/tie handling
- desired_state/fingerprint/MatchDecision build
- source-dedup via ISourceDedupStore (drop row + diagnostics on duplicate/conflict)
end note

note bottom of PlanningPipeline
Planning path lifecycle touchpoint:
`open()` resets dedup_store before each run.
Matcher core/stage do not own dedup_store lifecycle.
end note

note bottom of PlanningPipelineHooks
Match runtime scope cleanup is hook-driven:
`on_stage_complete("match") -> match_scope.clear_scope()`.
This is separate from LocalSourceDedupStore reset.
end note

note bottom of ScopedSourceDedupStore
Alternative implementation for cross-run scoped dedup via MatchRuntimePort.
Current PipelineContainer wiring uses LocalSourceDedupStore.
end note

@enduml
