@startuml
title Matcher Stage - Activity Diagram (Current)
skinparam backgroundColor white
skinparam linetype ortho
skinparam defaultFontName Arial
skinparam activity {
  BackgroundColor #f7e9dc
  BorderColor #d9c2a8
}

start
:MatchUseCase.run() consumes MATCH checkpoint pipeline\n(via PipelineOrchestrator);
note right
Planning path (adjacent flow):
PlanningPipeline.open() resets dedup_store before each run.
MatchStage / MatchCore do not own reset().
end note

:PipelineOrchestrator invokes MatchStage.run(enriched_stream);

repeat
  :Collect micro-batch in MatchStage\n(iter_micro_batches using IMatchBatchSettings);

  repeat
    if (enriched.row is None?) then (yes)
      :Pass through TransformResult unchanged;
    else (no)
      :Enter diagnostic_boundary(MATCH);
      :MatchEngine.match_with_source_dedup(enriched);
      :MatchCore.match_with_source_dedup(...);

      note right
        MatchCore.match(...) summary:
        - build MatchContext from TransformResult
        - identity exact lookup by MatchingRules.identity_rules
        - if no exact and fuzzy.enabled: collect blocking candidates
          + rank_candidates() + is_tie() + threshold decision
        - build desired_state via ResolveRules.build_desired_state(...)
        - build fingerprint + MatchDecision + MatchedRow
      end note

      if (match() returned row=None?) then (yes)
        :Emit TransformResult[row=None]\n(identity missing / target conflict / other match error);
      else (no)
        if (source_dedup enabled AND dedup_key exists?) then (yes)
          :dedup_store.check_and_register(dedup_key, fingerprint);
          if (DedupResult.is_first?) then (yes)
            :Emit TransformResult[MatchedRow];
          elseif (is_duplicate?) then (yes)
            :Drop row; set meta.match_drop_reason=duplicate_source;\nadd MATCH_DUPLICATE_SOURCE warning;
            :Emit TransformResult[row=None];
          else (conflict)
            :Drop row; set meta.match_drop_reason=conflict_source;\nadd MATCH_CONFLICT_SOURCE warn/error by policy;
            :Emit TransformResult[row=None];
          endif
        else (no)
          :Emit TransformResult[MatchedRow];
        endif
      endif
    endif
  repeat while (More items in current micro-batch?) is (yes)

repeat while (More micro-batches?) is (yes)

:PipelineHooks.on_stage_complete("match")\n(only on full stage consumption);
:PlanningPipelineHooks -> match_scope.clear_scope();
stop

@enduml
