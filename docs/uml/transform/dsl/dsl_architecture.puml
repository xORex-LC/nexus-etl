@startuml
title DSL Stage Architecture (Current + Target)

skinparam componentStyle rectangle
skinparam defaultFontName Arial

package "Runtime Pipeline" {
  [MapStage] as MapStage
  [NormalizeStage] as NormalizeStage
  [EnrichStage] as EnrichStage
  [MatchStage] as MatchStage
  [ResolveStage] as ResolveStage
}

package "Stage DSL Layer" {
  [MappingSpec] as MappingSpec
  [NormalizeSpec] as NormalizeSpec
  [EnrichSpec] as EnrichSpec

  [MapperDsl] as MapperDsl
  [NormalizerDsl] as NormalizerDsl
  [EnricherDsl] as EnricherDsl
}

package "Stage Engine Layer" {
  [MapperEngine] as MapperEngine
  [NormalizerEngine] as NormalizerEngine
  [EnricherEngine] as EnricherEngine
}

package "Stage Core Layer" {
  [MapperCore] as MapperCore
  [NormalizerCore] as NormalizerCore
  [EnricherCore] as EnricherCore
}

package "Shared DSL Kernel" {
  [TransformationEngine] as TEngine
  [OperationRegistry] as Registry
  [ProviderGateway] as ProviderGateway
}

package "Dependencies" {
  [TransformProviderDeps] as ProviderDeps
  [Cache/Dictionaries/SecretStore] as ExternalDeps
}

MapStage --> MapperEngine
NormalizeStage --> NormalizerEngine
EnrichStage --> EnricherEngine

MapperEngine --> MapperCore
NormalizerEngine --> NormalizerCore
EnricherEngine --> EnricherCore

MapperEngine ..> MapperDsl : compile spec
NormalizerEngine ..> NormalizerDsl : compile spec
EnricherEngine ..> EnricherDsl : compile spec

MapperDsl --> MappingSpec
NormalizerDsl --> NormalizeSpec
EnricherDsl --> EnrichSpec

MapperCore ..> TEngine : apply ops
NormalizerCore ..> TEngine : apply ops
EnricherDsl ..> TEngine : ops in DSL rules
TEngine --> Registry

EnricherDsl --> ProviderGateway
EnricherCore --> ProviderDeps
ProviderDeps --> ExternalDeps
ProviderGateway --> ExternalDeps

note right of MatchStage
Current state:
Match/Resolve run as transform stages,
DSL migration planned separately.
end note

@enduml
