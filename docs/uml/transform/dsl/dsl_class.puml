@startuml
title DSL - Stage Model for Map/Normalize/Enrich (Current)

skinparam defaultFontName Arial

abstract class StageSpec
abstract class StageDsl
abstract class StageEngine
abstract class StageCore

class TransformationEngine {
  +apply(value, ops): EngineResult
  +with_core_ops(): TransformationEngine
}

class OperationRegistry {
  +register(name, op)
  +get(name)
}

class DslIssue {
  +code: str
  +message: str
  +severity: str
}

class EngineResult {
  +value
  +issues: DslIssue[*]
}

class MappingSpec
class NormalizeSpec
class EnrichSpec

class MapperDsl
class NormalizerDsl
class EnricherDsl

class MapperEngine
class NormalizerEngine
class EnricherEngine

class MapperCore
class NormalizerCore
class EnricherCore

class ProviderGateway
class TransformProviderDeps
class TransformResult<T>

StageSpec <|-- MappingSpec
StageSpec <|-- NormalizeSpec
StageSpec <|-- EnrichSpec

StageDsl <|-- MapperDsl
StageDsl <|-- NormalizerDsl
StageDsl <|-- EnricherDsl

StageEngine <|-- MapperEngine
StageEngine <|-- NormalizerEngine
StageEngine <|-- EnricherEngine

StageCore <|-- MapperCore
StageCore <|-- NormalizerCore
StageCore <|-- EnricherCore

MapperEngine --> MapperCore
NormalizerEngine --> NormalizerCore
EnricherEngine --> EnricherCore

MapperEngine ..> MapperDsl : compile
NormalizerEngine ..> NormalizerDsl : compile
EnricherEngine ..> EnricherDsl : compile

MapperCore ..> TransformationEngine
NormalizerCore ..> TransformationEngine
EnricherDsl ..> TransformationEngine
TransformationEngine --> OperationRegistry

EnricherDsl --> ProviderGateway
EnricherCore --> TransformProviderDeps

MapperEngine ..> TransformResult
NormalizerEngine ..> TransformResult
EnricherEngine ..> TransformResult

note right of StageCore
Principle:
- StageCore contains stage business logic
- TransformationEngine contains only op execution
end note

@enduml
