@startuml
title Planning Resolve Flow - ResolveContextStage + ResolveStage (Current)
autonumber
hide footbox
skinparam backgroundColor white
skinparam linetype ortho
skinparam sequenceMessageAlign center
skinparam defaultFontName Arial
skinparam sequence {
  ArrowColor #4b5563
  LifeLineBorderColor #9ca3af
}

actor "PlanningPipeline.open()" as PlanningPipeline
participant "PipelineComposer\n(checkpoint RESOLVE_CONTEXT)" as Composer
participant "ResolveUseCase" as ResolveUseCase
participant "ResolveContextStage\n(lazy iterator in pre-resolve chain)" as ResolveContextStage
participant "IBatchIndexService" as BatchIndex
participant "PipelineOrchestrator\n([ResolveStage], hooks)" as ResolveSegment
participant "ResolveStage" as ResolveStage
participant "ResolveEngine" as ResolveEngine
participant "ResolveCore" as ResolveCore
participant "ResolveRuntimePort adapter\n(pending_replay + cache_gateway)" as RuntimePort
participant "Pending codec boundary\n(load helper + IPendingCodec impl)" as PendingCodec
participant "PlanningPipelineHooks" as ResolveHooks
participant "PendingExpiryService" as PendingExpiry

PlanningPipeline -> Composer: compose(RESOLVE_CONTEXT, hooks)
Composer --> PlanningPipeline: pre_resolve segment (... -> match -> resolve_context)
PlanningPipeline -> PlanningPipeline: contextualized = pre_resolve.run(extractor.run())\n(lazy stream ending at ResolveContextStage)
PlanningPipeline -> ResolveUseCase: iter_resolved(\n  matched_source=contextualized,\n  resolve_stage, dataset, pending_replay, resolve_hooks\n)

ResolveUseCase -> RuntimePort: list_pending_rows(dataset)
RuntimePort --> ResolveUseCase: pending rows (raw payloads)
ResolveUseCase -> PendingCodec: load_pending_rows(pending_rows)
PendingCodec --> ResolveUseCase: decoded pending TransformResult rows + skipped count
ResolveUseCase -> ResolveUseCase: chain(contextualized, pending_rows)

loop each resolve micro-batch (iter_micro_batches)
  ResolveUseCase -> RuntimePort: transaction() [if supported]
  RuntimePort --> ResolveUseCase: tx context

  opt first pull reaches contextualized iterator (once per run)
    ResolveUseCase -> ResolveContextStage: pull next matched item(s)
    activate ResolveContextStage
    ResolveContextStage -> ResolveContextStage: all_records = list(source)\n(buffer full matched stream for this checkpoint run)
    ResolveContextStage -> ResolveEngine: build_batch_index(all_records)
    ResolveEngine -> ResolveCore: build_batch_index(all_records)
    ResolveCore --> ResolveEngine: flat {lookup_key -> [resolved_id]}
    ResolveEngine --> ResolveContextStage: index
    ResolveContextStage -> BatchIndex: set_index(index)
    ResolveContextStage --> ResolveUseCase: emit buffered matched rows (unchanged)
    deactivate ResolveContextStage
  end

  ResolveUseCase -> ResolveSegment: run(batch)
  ResolveSegment -> ResolveStage: run(batch)

  loop each matched TransformResult in batch
    alt first item in ResolveStage.run()
      ResolveStage -> BatchIndex: get()
      BatchIndex --> ResolveStage: batch_index
    end

    alt matched.row is None
      ResolveStage --> ResolveSegment: passthrough TransformResult (row=None)
    else matched.row present
      ResolveStage -> ResolveEngine: resolve(matched.row, target_id_map={}, meta, batch_index)
      ResolveEngine -> ResolveCore: resolve(...)
      activate ResolveCore
      note right of ResolveCore
        ResolveCore.resolve() (high level):
        1) match conflict guard
        2) merge_policy (optional)
        3) link resolution (batch_index -> cache fallback)
        4) sink validation for mutated fields
        5) target_id + op/changes + ResolvedRow
      end note

      alt batch_index miss (or empty) during link resolution
        ResolveCore -> RuntimePort: find_candidates(dataset, lookup_key)
        RuntimePort --> ResolveCore: candidate ids
      else batch_index hit
        ResolveCore -> ResolveCore: use in-batch candidate ids
      end

      alt unresolved link and on_unresolved == pending
        ResolveCore -> PendingCodec: serialize(...) via IPendingCodec
        PendingCodec --> ResolveCore: payload json
        ResolveCore -> RuntimePort: add_pending(..., payload)
        RuntimePort --> ResolveCore: pending_id
        ResolveCore -> RuntimePort: touch_attempt(pending_id)
        RuntimePort --> ResolveCore: attempts
        alt attempts >= pending_max_attempts
          ResolveCore -> RuntimePort: mark_conflict(pending_id, "max attempts reached")
        end
      else successful resolve without pending
        ResolveCore -> RuntimePort: mark_resolved_for_source(source_row_id)
      end

      ResolveCore --> ResolveEngine: (ResolvedRow | None, errors, warnings)
      deactivate ResolveCore
      ResolveEngine --> ResolveStage: tuple result
      ResolveStage --> ResolveSegment: TransformResult[ResolvedRow | None]
    end
  end

  ResolveSegment -> ResolveHooks: on_stage_complete("resolve", duration_ms, stats)
  ResolveHooks -> PendingExpiry: sweep()
  PendingExpiry -> RuntimePort: sweep_expired(now_iso, reason="expired")\n(interval-guarded)
  RuntimePort --> PendingExpiry: expired pending links (optional)
end

note over ResolveUseCase, PendingExpiry
Expired links are drained outside stage internals:
- ResolveUseCase.run(): drain + report after batches
- PlanningPipeline.open(): drain in finally (cleanup only)
end note

@enduml
