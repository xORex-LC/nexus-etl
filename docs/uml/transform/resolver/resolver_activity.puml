@startuml
title Resolver Mechanics - Activity Flow (Planning Path, Current)
skinparam backgroundColor white
skinparam linetype ortho
skinparam defaultFontName Arial
skinparam activity {
  BackgroundColor #f7e9dc
  BorderColor #d9c2a8
}

start
:PlanningPipeline.open();
:dedup_store.reset();
:Build lazy `contextualized` stream\nvia checkpoint RESOLVE_CONTEXT\n(... -> match -> ResolveContextStage);
:ResolveUseCase.iter_resolved(\nmatched_source=contextualized,\nresolve_stage, pending_replay, resolve_hooks);

if (pending replay enabled?) then (yes)
  :pending_replay.list_pending_rows(dataset);
  :Decode pending payloads\n(pending_codec.load_pending_rows);
  :Append decoded pending rows to matched_source;
else (no)
  :Use matched_source as-is;
endif

repeat
  :Open ResolveRuntimePort transaction\nif resolver.cache_gateway supports it;
  :Collect next resolve micro-batch\n(iter_micro_batches over chained source);

  if (First pull from contextualized stream in this run?) then (yes)
    :ResolveContextStage buffers full upstream matched stream;
    :resolver.build_batch_index(all_records);
    :IBatchIndexService.set_index(flat batch_index);
    :ResolveContextStage yields buffered records unchanged;
  else (no)
    :Continue consuming buffered/contextualized rows;
  endif

  :Run micro-batch through\nPipelineOrchestrator([ResolveStage], hooks);

  repeat
    if (TransformResult.row is None?) then (yes)
      :ResolveStage passes item through unchanged;
    else (no)
      if (ResolveStage already loaded batch_index?) then (yes)
        :Reuse cached batch_index in ResolveStage.run();
      else (no)
        :IBatchIndexService.get()\n(lazy, once per ResolveStage.run);
      endif

      :ResolveStage enters diagnostic_boundary(RESOLVE)\nand calls resolver.resolve(..., batch_index);
      note right
        ResolveCore.resolve() owns business mechanics:
        - match conflict guard (AMBIGUOUS / CONFLICT_SOURCE)
        - optional merge_policy (preserve explicit source values)
        - FK/link resolution per LinkRules
          * batch_index lookup first
          * cache_gateway.find_candidates() fallback
          * dedup rules narrowing
          * unresolved -> hard_error OR pending(add_pending/touch_attempt)
          * max attempts -> mark_conflict
        - sink validation for mutated fields (SinkSpec)
        - target_id resolution and op decision (create/update/skip)
        - ResolvedRow build + mark_resolved_for_source() when no pending
      end note

      if (resolver.resolve() returned ResolvedRow?) then (yes)
        :Emit TransformResult[ResolvedRow];
      else (no)
        :Emit TransformResult with row=None\n+ resolve diagnostics (errors/warnings);
      endif
    endif
  repeat while (More items in current resolve micro-batch?) is (yes)

  :PipelineHooks.on_stage_complete("resolve")\n(after full batch consumption);
  :PlanningPipelineHooks -> pending_expiry.sweep()\n(interval guarded);
repeat while (More resolve micro-batches?) is (yes)

:Expired pending handling stays outside stage internals:\nResolveUseCase.run() drains/reports,\nPlanningPipeline.open() drains in finally for cleanup;
stop

@enduml
