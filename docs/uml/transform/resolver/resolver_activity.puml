@startuml
title Resolver Stage - Activity Diagram (Current)
skinparam backgroundColor white
skinparam linetype ortho
skinparam defaultFontName Arial
skinparam activity {
  BackgroundColor #f7e9dc
  BorderColor #d9c2a8
  FontColor #1f1f1f
}

start
:maybe_sweep_expired();

if (match_decision.status in\n{AMBIGUOUS, CONFLICT_SOURCE}?) then (yes)
  :append RESOLVE_AMBIGUOUS/RESOLVE_CONFLICT;
  stop
endif

:desired_state = matched.desired_state;
if (merge_policy configured?) then (yes)
  :desired_state = merge_policy(existing, desired_state);
endif

repeat
  :take next LinkFieldRule;
  if (field absent or value None?) then (skip)
    :continue;
  else (process)
    :extract key_values\n(meta overrides + desired_state);
    :lookup candidates\n(batch_index -> identity_repo);
    if (single candidate?) then (yes)
      :coerce candidate id;
      :write desired_state[field];
    else (no)
      if (on_unresolved == hard_error?) then (yes)
        :append RESOLVE_CONFLICT;
        stop
      else (pending)
        :add pending + touch_attempt;
        if (attempts >= max?) then (yes)
          :mark conflict;
          :append RESOLVE_MAX_ATTEMPTS;
          stop
        else (no)
          :append RESOLVE_PENDING warning;
          if (allow_partial?) then (yes)
            :continue;
          else (no)
            stop
          endif
        endif
      endif
    endif
  endif
repeat while (more rules?) is (yes)

if (sink_spec configured and\nmutated_fields not empty?) then (yes)
  :validate_sink_fields(mutated_fields);
  if (sink issues?) then (yes)
    :append diagnostics from sink issues;
    stop
  endif
endif

:target_id = resolve_target_id();
if (target_id missing?) then (yes)
  :append RESOLVE_TARGET_ID_MISSING;
  stop
endif

:op, changes = decide_op();
:source_ref = build_source_ref(identity);
:secret_fields = secrets_policy(op);
:build ResolvedRow;
if (pending_created == false?) then (yes)
  :mark_resolved_for_source(row_id);
endif
stop

@enduml
