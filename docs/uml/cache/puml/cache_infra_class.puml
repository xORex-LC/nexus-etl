@startuml
title Cache Infra View (SQLite Gateway Composition)

skinparam classAttributeIconSize 0
skinparam linetype ortho
hide empty members

package "domain contracts" {
  interface CacheAdminPort <<protocol>>
  interface EnrichLookupPort <<protocol>>
  interface MatchRuntimePort <<protocol>>
  interface ResolveRuntimePort <<protocol>>
  interface ApplyRuntimePort <<protocol>>

  class CacheMeta
  class PendingLink
  class PendingRow
  enum UpsertResult
}

package "infra.cache" {
  class SqliteEngine {
    +transaction()
    +execute(sql: str, params: tuple = ())
    +fetchone(sql: str, params: tuple = ())
    +fetchall(sql: str, params: tuple = ())
  }

  class SqliteCacheRepository {
    -engine: SqliteEngine
    -_handlers: dict[str, GenericCacheHandler]
    +transaction(): Iterator[None]
    +upsert(dataset: str, write_model: dict): UpsertResult
    +count(dataset: str): int
    +count_by_table(dataset: str): dict[str, int]
    +clear(dataset: str): None
    +list_datasets(): list[str]
    +get_meta(dataset: str | None): CacheMeta
    +set_meta(dataset: str | None, key: str, value: str | None): None
    +reset_meta(dataset: str): None
    +find(dataset: str, filters: dict[str, Any], include_deleted: bool, mode: str): list[dict]
    +find_one(dataset: str, filters: dict[str, Any], include_deleted: bool, mode: str): dict | None
  }

  class SqliteIdentityRepository {
    -engine: SqliteEngine
    +upsert_identity(dataset: str, identity_key: str, resolved_id: str): None
    +find_candidates(dataset: str, identity_key: str): list[str]
    +set_runtime_state(scope: str, dataset: str, state_key: str, state_value: str): None
    +get_runtime_state(scope: str, dataset: str, state_key: str): str | None
    +clear_runtime_scope(scope: str): None
  }

  class SqlitePendingLinksRepository {
    -engine: SqliteEngine
    +add_pending(dataset: str, source_row_id: str, field: str, lookup_key: str, expires_at: str | None, payload: str | None): int
    +list_pending_for_key(dataset: str, lookup_key: str): list[PendingLink]
    +list_pending_rows(dataset: str): list[PendingRow]
    +mark_resolved(pending_id: int): None
    +mark_resolved_for_source(source_row_id: str): None
    +mark_conflict(pending_id: int, reason: str | None): None
    +mark_expired(pending_id: int, reason: str | None): None
    +touch_attempt(pending_id: int): int
    +sweep_expired(now: str, reason: str | None): list[PendingLink]
    +purge_stale(cutoff: str, statuses: tuple[str, ...] | None): int
  }

  class SqliteCacheGateway {
    -_cache_repo: SqliteCacheRepository
    -_identity_repo: SqliteIdentityRepository
    -_pending_repo: SqlitePendingLinksRepository
    +transaction()
    +upsert(dataset: str, write_model: dict): UpsertResult
    +count(dataset: str): int
    +count_by_table(dataset: str): dict[str, int]
    +clear(dataset: str): None
    +list_datasets(): list[str]
    +get_meta(dataset: str | None): CacheMeta
    +set_meta(dataset: str | None, key: str, value: str | None): None
    +reset_meta(dataset: str): None
    +find(dataset: str, filters: dict[str, Any], include_deleted: bool, mode: str): list[dict]
    +find_one(dataset: str, filters: dict[str, Any], include_deleted: bool, mode: str): dict | None
    +upsert_identity(dataset: str, identity_key: str, resolved_id: str): None
    +find_candidates(dataset: str, identity_key: str): list[str]
    +set_runtime_state(scope: str, dataset: str, state_key: str, state_value: str): None
    +get_runtime_state(scope: str, dataset: str, state_key: str): str | None
    +clear_runtime_scope(scope: str): None
    +add_pending(dataset: str, source_row_id: str, field: str, lookup_key: str, expires_at: str | None, payload: str | None): int
    +list_pending_for_key(dataset: str, lookup_key: str): list[PendingLink]
    +list_pending_rows(dataset: str): list[PendingRow]
    +mark_resolved(pending_id: int): None
    +mark_resolved_for_source(source_row_id: str): None
    +mark_conflict(pending_id: int, reason: str | None): None
    +mark_expired(pending_id: int, reason: str | None): None
    +touch_attempt(pending_id: int): int
    +sweep_expired(now: str, reason: str | None): list[PendingLink]
    +purge_stale(cutoff: str, statuses: tuple[str, ...] | None): int
  }

  class build_sqlite_cache_gateway <<factory>> {
    +build_sqlite_cache_gateway(engine: SqliteEngine, cache_specs: Iterable[CacheSpec]): SqliteCacheGateway
  }
}

SqliteCacheGateway *-- SqliteCacheRepository
SqliteCacheGateway *-- SqliteIdentityRepository
SqliteCacheGateway *-- SqlitePendingLinksRepository

SqliteCacheRepository --> SqliteEngine
SqliteIdentityRepository --> SqliteEngine
SqlitePendingLinksRepository --> SqliteEngine

build_sqlite_cache_gateway ..> SqliteCacheGateway : creates
build_sqlite_cache_gateway ..> SqliteCacheRepository : creates
build_sqlite_cache_gateway ..> SqliteIdentityRepository : creates
build_sqlite_cache_gateway ..> SqlitePendingLinksRepository : creates

SqliteCacheGateway ..|> CacheAdminPort
SqliteCacheGateway ..|> EnrichLookupPort
SqliteCacheGateway ..|> MatchRuntimePort
SqliteCacheGateway ..|> ResolveRuntimePort
SqliteCacheGateway ..|> ApplyRuntimePort

note right of SqliteCacheGateway
Single runtime object for DI.
Internally composes three specialized
SQLite repositories.
end note

@enduml
