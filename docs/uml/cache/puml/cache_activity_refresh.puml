@startuml
title Cache Activity - Refresh Flow

start
:Open cache transaction;
:Read source page;
if (Rows in page?) then (yes)
  :Map source row to cache model;
  :Upsert row into cache table;
  :Upsert identity links;
  :Try resolve pending by identity key;
  if (Pending rows found?) then (yes)
    :Mark pending as resolved;
  endif
  :Collect counters and stats;
  :Read next page;
  repeat
    :Map and upsert next rows;
    :Sync identity + pending;
    :Update stats;
  repeat while (More pages?) is (yes)
  -> no;
else (no)
endif
:Write cache meta (last_refresh_at, pages, rows, count_total);
:Commit transaction;
stop

@enduml

