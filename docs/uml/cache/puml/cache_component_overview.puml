@startuml
title Cache Component Overview

left to right direction
skinparam componentStyle rectangle
skinparam linetype ortho

actor CLI

package "Delivery / UseCases" {
  [Enrich command]
  [Match command]
  [Resolve command]
  [Cache refresh command]
  [Import apply command]

  [EnrichUseCase]
  [MatchUseCase]
  [ResolveUseCase]
  [CacheRefreshUseCase]
  [ImportApplyService]
}

package "Domain stages" {
  [EnrichStage]
  [MatchStage]
  [ResolveStage]
}

package "Domain contracts (roles)" {
  interface "EnrichLookupPort" as EnrichLookupPort
  interface "MatchRuntimePort" as MatchRuntimePort
  interface "ResolveRuntimePort" as ResolveRuntimePort
  interface "ApplyRuntimePort" as ApplyRuntimePort
  interface "CacheAdminPort" as CacheAdminPort
}

package "Infra cache" {
  [SqliteCacheGateway]
  [SqliteCacheRepository]
  [SqliteIdentityRepository]
  [SqlitePendingLinksRepository]
  database "SQLite DB" as SQLiteDB
}

CLI --> [Enrich command]
CLI --> [Match command]
CLI --> [Resolve command]
CLI --> [Cache refresh command]
CLI --> [Import apply command]

[Enrich command] --> [EnrichUseCase]
[Match command] --> [MatchUseCase]
[Resolve command] --> [ResolveUseCase]
[Cache refresh command] --> [CacheRefreshUseCase]
[Import apply command] --> [ImportApplyService]

[EnrichUseCase] --> [EnrichStage]
[MatchUseCase] --> [MatchStage]
[ResolveUseCase] --> [ResolveStage]

[EnrichStage] ..> EnrichLookupPort
[MatchStage] ..> MatchRuntimePort
[ResolveStage] ..> ResolveRuntimePort
[CacheRefreshUseCase] ..> CacheAdminPort
[CacheRefreshUseCase] ..> ApplyRuntimePort
[ImportApplyService] ..> ApplyRuntimePort

[SqliteCacheGateway] ..|> EnrichLookupPort
[SqliteCacheGateway] ..|> MatchRuntimePort
[SqliteCacheGateway] ..|> ResolveRuntimePort
[SqliteCacheGateway] ..|> ApplyRuntimePort
[SqliteCacheGateway] ..|> CacheAdminPort

[SqliteCacheGateway] *--> [SqliteCacheRepository]
[SqliteCacheGateway] *--> [SqliteIdentityRepository]
[SqliteCacheGateway] *--> [SqlitePendingLinksRepository]

[SqliteCacheRepository] --> SQLiteDB
[SqliteIdentityRepository] --> SQLiteDB
[SqlitePendingLinksRepository] --> SQLiteDB

note right of [SqliteCacheGateway]
Single runtime object in DI.
Role-typed usage by stage/use-case.
end note

@enduml
