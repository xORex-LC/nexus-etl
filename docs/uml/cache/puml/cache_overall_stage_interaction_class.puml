@startuml
title Cache Overall Interaction (Dataset Spec -> Stages -> Roles -> Infra)
set namespaceSeparator none
skinparam backgroundColor white
skinparam linetype ortho
skinparam defaultFontName Arial
skinparam class {
  BackgroundColor #f7e9dc
  BorderColor #d9c2a8
}
hide empty members

package "dataset wiring" {
  interface DatasetSpec <<protocol>> {
    +build_enrich_deps(settings, enrich_lookup, secret_store): TransformProviderDeps
    +build_planning_deps(settings, planning_runtime): PlanningDependencies
    +build_enrich_stage(catalog, enrich_deps): EnrichStage
    +build_match_stage(planning_deps, catalog, include_deleted, settings): MatchStage
    +build_resolve_stage(planning_deps, catalog, settings): ResolveStage
  }

  class EmployeesSpec
}

package "stage deps (domain)" {
  class TransformProviderDeps {
    +cache_gateway: EnrichLookupPort
  }

  class PlanningDependencies {
    +planning_runtime: PlanningRuntimePort | None
    +resolver_settings: ResolverSettings | None
  }
}

package "stages" {
  class EnrichStage
  class MatchStage
  class ResolveStage

  class EnricherEngine
  class MatchEngine
  class ResolveEngine
}

package "domain role ports" {
  interface EnrichLookupPort <<protocol>>
  interface PlanningRuntimePort <<protocol>>
}

package "infra runtime + adapters" {
  class SqliteCacheGateway {
    +cache: SqliteCacheRepository
    +identity: SqliteIdentityRepository
    +pending: SqlitePendingLinksRepository
    +open(settings, cache_specs)
    +from_engine(engine, cache_specs, owns_connection)
  }

  class SqliteEnrichLookupAdapter
  class SqlitePlanningRuntimeAdapter
  class SqliteCacheRolePorts {
    +enrich_lookup: EnrichLookupPort
    +planning_runtime: PlanningRuntimePort
  }
}

DatasetSpec <|.. EmployeesSpec

EmployeesSpec ..> TransformProviderDeps : builds
EmployeesSpec ..> PlanningDependencies : builds
EmployeesSpec ..> EnrichStage : builds
EmployeesSpec ..> MatchStage : builds
EmployeesSpec ..> ResolveStage : builds

TransformProviderDeps ..> EnrichLookupPort
PlanningDependencies ..> PlanningRuntimePort

EnrichStage --> EnricherEngine
MatchStage --> MatchEngine
ResolveStage --> ResolveEngine

SqliteEnrichLookupAdapter ..|> EnrichLookupPort
SqlitePlanningRuntimeAdapter ..|> PlanningRuntimePort
SqliteEnrichLookupAdapter --> SqliteCacheGateway
SqlitePlanningRuntimeAdapter --> SqliteCacheGateway

SqliteCacheRolePorts ..> EnrichLookupPort
SqliteCacheRolePorts ..> PlanningRuntimePort

note right of SqliteCacheRolePorts
Built in wiring:
build_sqlite_cache_role_ports(gateway)
end note

note right of EmployeesSpec
Domain stays role-typed.
No direct dependency on Sqlite classes.
end note

@enduml
