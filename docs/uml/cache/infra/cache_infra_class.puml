@startuml
title Cache Infra Class View (Namespaced Gateway + Role Adapters)
set namespaceSeparator none
skinparam backgroundColor white
skinparam linetype ortho
skinparam defaultFontName Arial
skinparam class {
  BackgroundColor #f7e9dc
  BorderColor #d9c2a8
}
hide empty members

package "domain ports" {
  interface CacheAdminPort <<protocol>>
  interface CacheRefreshPort <<protocol>>
  interface EnrichLookupPort <<protocol>>
  interface PlanningRuntimePort <<protocol>>
  interface PendingReplayPort <<protocol>>
  interface ApplyRuntimePort <<protocol>>
}

package "infra.cache.backends.sqlite" {
  class SqliteEngine {
    +transaction()
    +execute(sql, params)
    +fetchone(sql, params)
    +fetchall(sql, params)
  }

  class SqliteCacheRepository {
    +upsert(dataset, write_model)
    +find(dataset, filters, include_deleted, mode)
    +find_one(dataset, filters, include_deleted, mode)
    +count(dataset)
    +count_by_table(dataset)
    +clear(dataset)
    +list_datasets()
    +get_meta(dataset)
    +set_meta(dataset, key, value)
  }

  class SqliteIdentityRepository {
    +upsert_identity(dataset, identity_key, resolved_id)
    +find_candidates(dataset, identity_key)
    +set_runtime_state(scope, dataset, key, value)
    +get_runtime_state(scope, dataset, key)
    +clear_runtime_scope(scope)
  }

  class SqlitePendingLinksRepository {
    +add_pending(dataset, source_row_id, field, lookup_key, expires_at, payload)
    +list_pending_for_key(dataset, lookup_key)
    +list_pending_rows(dataset)
    +mark_resolved(pending_id)
    +mark_resolved_for_source(source_row_id)
    +mark_conflict(pending_id, reason)
    +touch_attempt(pending_id)
    +sweep_expired(now, reason)
    +purge_stale(cutoff, statuses)
  }
}

package "infra.cache gateway" {
  class SqliteCacheGateway {
    +cache: SqliteCacheRepository
    +identity: SqliteIdentityRepository
    +pending: SqlitePendingLinksRepository
    +open(settings, cache_specs)
    +from_engine(engine, cache_specs, owns_connection)
    +transaction()
    +close()
  }
}

package "infra.cache.roles" {
  class SqliteCacheAdminAdapter
  class SqliteCacheRefreshAdapter
  class SqliteEnrichLookupAdapter
  class SqlitePlanningRuntimeAdapter
  class SqliteApplyRuntimeAdapter

  class SqliteCacheRolePorts {
    +cache_admin: CacheAdminPort
    +cache_refresh: CacheRefreshPort
    +enrich_lookup: EnrichLookupPort
    +planning_runtime: PlanningRuntimePort
    +pending_replay: PendingReplayPort
    +apply_runtime: ApplyRuntimePort
  }
}

SqliteCacheGateway *-- SqliteCacheRepository
SqliteCacheGateway *-- SqliteIdentityRepository
SqliteCacheGateway *-- SqlitePendingLinksRepository
SqliteCacheGateway --> SqliteEngine

SqliteCacheRepository --> SqliteEngine
SqliteIdentityRepository --> SqliteEngine
SqlitePendingLinksRepository --> SqliteEngine

SqliteCacheAdminAdapter --> SqliteCacheGateway
SqliteEnrichLookupAdapter --> SqliteCacheGateway
SqlitePlanningRuntimeAdapter --> SqliteCacheGateway
SqliteApplyRuntimeAdapter --> SqliteCacheGateway
SqliteCacheRefreshAdapter --> SqliteCacheAdminAdapter
SqliteCacheRefreshAdapter --> SqliteApplyRuntimeAdapter

SqliteCacheAdminAdapter ..|> CacheAdminPort
SqliteCacheRefreshAdapter ..|> CacheRefreshPort
SqliteEnrichLookupAdapter ..|> EnrichLookupPort
SqlitePlanningRuntimeAdapter ..|> PlanningRuntimePort
SqlitePlanningRuntimeAdapter ..|> PendingReplayPort
SqliteApplyRuntimeAdapter ..|> ApplyRuntimePort

note right of SqliteCacheGateway
Gateway is wiring/lifecycle facade:
- namespaced repositories
- unified transaction boundary
- ownership-aware close()
end note

note right of SqliteCacheRolePorts
Role bundle is injected into
domain/use-cases.
Domain never depends on gateway directly.
end note

@enduml
