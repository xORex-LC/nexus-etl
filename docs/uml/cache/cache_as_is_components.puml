@startuml
title Cache Access Architecture - AS IS

skinparam componentStyle rectangle
skinparam defaultFontName Arial

package "Dataset Wiring" {
  [EmployeesSpec] as EmployeesSpec
  [build_transform_provider_deps] as BuildTransformDeps
  [build_planning_dependencies] as BuildPlanningDeps
}

package "Domain Ports" {
  interface "CacheRepositoryProtocol" as CacheRepoPort
  interface "IdentityRepositoryPort" as IdentityRepoPort
  interface "PendingLinksRepositoryPort" as PendingRepoPort
}

package "Infra Cache Adapters" {
  [SqliteCacheRepository] as SqliteCacheRepo
  [SqliteIdentityRepository] as SqliteIdentityRepo
  [SqlitePendingLinksRepository] as SqlitePendingRepo
}

package "Use Cases" {
  [Map/Normalize/Enrich] as TransformStages
  [Match/Resolve] as PlanningStages
}

EmployeesSpec --> BuildTransformDeps
EmployeesSpec --> BuildPlanningDeps

BuildTransformDeps --> SqliteCacheRepo
BuildPlanningDeps --> SqliteIdentityRepo
BuildPlanningDeps --> SqlitePendingRepo

SqliteCacheRepo ..|> CacheRepoPort
SqliteIdentityRepo ..|> IdentityRepoPort
SqlitePendingRepo ..|> PendingRepoPort

TransformStages --> CacheRepoPort
PlanningStages --> IdentityRepoPort
PlanningStages --> PendingRepoPort

note bottom of EmployeesSpec
Issue:
- multiple infra objects are wired separately
- duplicated cache wiring logic in spec
end note

@enduml
