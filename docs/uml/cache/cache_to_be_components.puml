@startuml
title Cache Access Architecture - TO BE

skinparam componentStyle rectangle
skinparam defaultFontName Arial
skinparam component<<new>> {
  BackgroundColor #E8F5E9
  BorderColor #2E7D32
}

package "Dataset Wiring" {
  [EmployeesSpec] as EmployeesSpec
  [build_enrich_deps] as BuildEnrichDeps
  [build_planning_deps] as BuildPlanningDeps
  [TransformProviderDeps] as TransformDeps
  [PlanningDependencies] as PlanningDeps
}

package "Composition Root (Delivery/Bootstrap)" {
  [build_cache_gateway] <<new>> as BuildCacheGateway
  [build_pipeline_context] as BuildPipelineContext
}

package "Domain Ports" {
  interface "CacheGatewayPort" <<new>> as CacheGatewayPort
}

package "Infra Cache Gateway" {
  [SqliteCacheGateway] as SqliteGateway
  [SqliteCacheRepository] as SqliteCacheRepo
  [SqliteIdentityRepository] as SqliteIdentityRepo
  [SqlitePendingLinksRepository] as SqlitePendingRepo
}

package "Use Cases" {
  [Map/Normalize/Enrich stages] as TransformStages
  [Match/Resolve stages] as PlanningStages
  [ImportPlanService] as ImportPlanService
}

EmployeesSpec --> BuildEnrichDeps
EmployeesSpec --> BuildPlanningDeps
BuildEnrichDeps --> TransformDeps
BuildPlanningDeps --> PlanningDeps
BuildCacheGateway --> SqliteGateway
BuildPipelineContext --> BuildCacheGateway
BuildPipelineContext --> BuildEnrichDeps : injects cache_gateway
BuildPipelineContext --> BuildPlanningDeps : injects cache_gateway

SqliteGateway ..|> CacheGatewayPort
SqliteGateway --> SqliteCacheRepo : delegates
SqliteGateway --> SqliteIdentityRepo : delegates
SqliteGateway --> SqlitePendingRepo : delegates

TransformDeps --> CacheGatewayPort
PlanningDeps --> CacheGatewayPort

TransformStages --> CacheGatewayPort
PlanningStages --> CacheGatewayPort
ImportPlanService --> CacheGatewayPort

note bottom of TransformDeps
Benefits:
- no direct SQLite dependency in spec deps builders
- SQLite selection only in composition root
- one cache gateway port for transform/planning/apply
- one domain cache boundary instead of multiple ports
end note

note right of SqliteGateway
Internal delegates keep
storage concerns separated:
- snapshot cache
- identity index
- pending links
end note

@enduml
