@startuml
title Cache Access Architecture - TO BE

skinparam componentStyle rectangle
skinparam defaultFontName Arial
skinparam component<<new>> {
  BackgroundColor #E8F5E9
  BorderColor #2E7D32
}

package "Dataset Wiring" {
  [EmployeesSpec] as EmployeesSpec
  [build_runtime_deps] as BuildRuntimeDeps
  [TransformRuntimeDeps] as RuntimeDeps
}

package "Composition Root (Delivery/Bootstrap)" {
  [build_cache_gateway] <<new>> as BuildCacheGateway
}

package "Domain Ports" {
  interface "CacheRepositoryProtocol" as CacheRepoPort
  interface "IdentityRepositoryPort" as IdentityRepoPort
  interface "PendingLinksRepositoryPort" as PendingRepoPort
}

package "Infra Cache Gateway" {
  [SqliteCacheGateway] as SqliteGateway
  [SqliteCacheRepository] as SqliteCacheRepo
  [SqliteIdentityRepository] as SqliteIdentityRepo
  [SqlitePendingLinksRepository] as SqlitePendingRepo
}

package "Use Cases" {
  [Map/Normalize/Enrich] as TransformStages
  [Match/Resolve] as PlanningStages
}

EmployeesSpec --> BuildRuntimeDeps
BuildRuntimeDeps --> RuntimeDeps
BuildCacheGateway --> SqliteGateway
BuildCacheGateway --> BuildRuntimeDeps : injects ports

SqliteGateway ..|> CacheRepoPort
SqliteGateway ..|> IdentityRepoPort
SqliteGateway ..|> PendingRepoPort
SqliteGateway --> SqliteCacheRepo : delegates
SqliteGateway --> SqliteIdentityRepo : delegates
SqliteGateway --> SqlitePendingRepo : delegates

RuntimeDeps --> CacheRepoPort
RuntimeDeps --> IdentityRepoPort
RuntimeDeps --> PendingRepoPort

TransformStages --> CacheRepoPort
PlanningStages --> IdentityRepoPort
PlanningStages --> PendingRepoPort

note bottom of RuntimeDeps
Benefits:
- no direct SQLite dependency in build_runtime_deps
- SQLite selection only in composition root
- one deps builder in spec
- separated ports remain (ISP-safe)
end note

@enduml
